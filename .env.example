# ============================================================================
# PoolGate Configuration
# ============================================================================
# Copy this file to `.env` and update the values as needed.
#
# Example:
# cp .env.example .env
#
# ============================================================================


# ============================================================================
# Groq API Keys (Required)
# ============================================================================
# Comma-separated list of Groq API keys used by the key pool.
#
# Example:
# GROQ_API_KEYS=gsk_xxxxxxxxxxxxx,gsk_yyyyyyyyyyyyy
#
# At least one valid API key is required for PoolGate to start.
#
GROQ_API_KEYS=


# ============================================================================
# Batch Processing
# ============================================================================
# Maximum number of requests that PoolGate will process concurrently when
# executing batch workloads.
#
# Higher values increase throughput but may cause rate limits to be reached
# more quickly depending on the available API keys and model limits.
#
GROQ_BATCH_CONCURRENCY=20


# ============================================================================
# Retry Configuration
# ============================================================================
# Maximum number of retry attempts for transient failures such as temporary
# network issues, service unavailability, or rate limiting.
#
GROQ_MAX_RETRIES=3

# Initial retry delay in seconds.
#
# Example retry schedule with:
#   GROQ_BASE_BACKOFF=1.0
#
# Retries occur after approximately:
#   1s → 2s → 4s → ...
#
GROQ_BASE_BACKOFF=1.0

# Maximum delay (in seconds) allowed between retry attempts.
#
# Prevents exponential backoff from growing indefinitely.
#
GROQ_MAX_BACKOFF=30.0


# ============================================================================
# Session Management
# ============================================================================
# Session lifetime in hours.
#
# Sessions older than this value may be automatically expired and cleaned up.
#
GROQ_SESSION_TTL_HOURS=24


# ============================================================================
# Logging & Diagnostics
# ============================================================================
# Enable verbose debugging output.
#
# Accepted values:
#   true, false
#   1, 0
#   yes, no
#
# Recommended:
#   false for production
#   true  for development and troubleshooting
#
GROQ_DEBUG=false

# Logging verbosity level.
#
# Supported values:
#   DEBUG
#   INFO
#   WARNING
#   ERROR
#   CRITICAL
#
# Recommended:
#   INFO  for normal operation
#   DEBUG when troubleshooting
#
GROQ_LOG_LEVEL=INFO