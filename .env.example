# ============================================================================
# PoolGate Environment Configuration
# ============================================================================

# Usage:
# cp .env.example .env

# Fill in at least one Groq API key before starting PoolGate.

# ============================================================================
# API Keys
# ============================================================================
# Number of configured API keys.
# PoolGate loads keys sequentially:

# TOTAL_GROQ_KEYS= <total-number-of-api-keys>

# GROQ_API_KEY_01
# ...
# ...
# GROQ_API_KEY_N

# Ensure TOTAL_GROQ_KEYS matches the number of key entries below.
# ============================================================================

TOTAL_GROQ_KEYS=10

GROQ_API_KEY_01=
GROQ_API_KEY_02=
GROQ_API_KEY_03=
GROQ_API_KEY_04=
GROQ_API_KEY_05=
GROQ_API_KEY_06=
GROQ_API_KEY_07=
GROQ_API_KEY_08=
GROQ_API_KEY_09=
GROQ_API_KEY_10=

# ============================================================================
# Throughput
# ============================================================================
# Maximum concurrent requests during batch operations.
# Increase for higher throughput; decrease to reduce rate-limit pressure.
# Built-in default when this variable is unset: 20

GROQ_BATCH_CONCURRENCY=50

# ============================================================================
# Retry Policy
# ============================================================================
# Automatic retries for transient failures:
# - Network issues
# - Rate limits
# - Temporary service errors
# Built-in default when this variable is unset: 3
GROQ_MAX_RETRIES=5

# Initial retry delay in seconds.
# Backoff progression:
# 1.0 → 2.0 → 4.0 → 8.0 ...
GROQ_BASE_BACKOFF=1.0

# Maximum retry delay in seconds.
GROQ_MAX_BACKOFF=30.0

# ============================================================================
# Session Management
# ============================================================================
# Session expiration time in hours.
# Expired sessions may be cleaned up automatically.
GROQ_SESSION_TTL_HOURS=24

# ============================================================================
# Logging
# ============================================================================
# Enable verbose debugging.
# Accepted: true | false | 1 | 0 | yes | no

GROQ_DEBUG=false

# Log level:
# DEBUG | INFO | WARNING | ERROR | CRITICAL
GROQ_LOG_LEVEL=INFO
