# ============================================================================
# PoolGate Environment Configuration
# ============================================================================

# Usage:
# cp .env.example .env

# Fill in at least one provider's API keys before using PoolGate.
# Groq and Google Gemini are configured independently — you can use
# either one or both at the same time.

# ============================================================================
# GROQ — API Keys
# ============================================================================
# Number of Groq API keys configured.
# PoolGate loads keys sequentially from GROQ_API_KEY_01 … GROQ_API_KEY_N.
# Ensure TOTAL_GROQ_KEYS matches the number of key entries below.

TOTAL_GROQ_KEYS=10

GROQ_API_KEY_01=
GROQ_API_KEY_02=
GROQ_API_KEY_03=
GROQ_API_KEY_04=
GROQ_API_KEY_05=
GROQ_API_KEY_06=
GROQ_API_KEY_07=
GROQ_API_KEY_08=
GROQ_API_KEY_09=
GROQ_API_KEY_10=

# ============================================================================
# GROQ — Rate Limiting
# ============================================================================
# Max requests per minute per key before PoolGate applies back-pressure.
# Built-in default when this variable is unset: 30
GROQ_MAX_RPM=30

# Max concurrent in-flight requests per key.
# Built-in default when this variable is unset: 10
GROQ_MAX_ACTIVE=10

# Seconds a key is held in cooldown after receiving a 429.
# Built-in default when this variable is unset: 60
GROQ_COOLDOWN_SECS=60

# Consecutive non-rate-limit failures before a key is marked FAILED.
# Built-in default when this variable is unset: 5
GROQ_FAILURE_THRESHOLD=5

# ============================================================================
# GROQ — Throughput
# ============================================================================
# Maximum concurrent requests during batch operations.
# Increase for higher throughput; decrease to reduce rate-limit pressure.
# Built-in default when this variable is unset: 20

GROQ_BATCH_CONCURRENCY=50

# ============================================================================
# GROQ — Retry Policy
# ============================================================================
# Automatic retries for transient failures:
# - Network issues
# - Rate limits
# - Temporary service errors
# Built-in default when this variable is unset: 3
GROQ_MAX_RETRIES=5

# Initial retry delay in seconds.
# Backoff progression: 1.0 → 2.0 → 4.0 → 8.0 ...
GROQ_BASE_BACKOFF=1.0

# Maximum retry delay cap in seconds.
GROQ_MAX_BACKOFF=30.0

# ============================================================================
# GROQ — Session Management
# ============================================================================
# Session expiration time in hours.
GROQ_SESSION_TTL_HOURS=24

# ============================================================================
# GROQ — Logging
# ============================================================================
# Enable verbose debugging.
# Accepted: true | false | 1 | 0 | yes | no
GROQ_DEBUG=false

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
GROQ_LOG_LEVEL=INFO

# ============================================================================
# GOOGLE GEMINI — API Keys
# ============================================================================
# Install the Gemini extra first:  pip install poolgate[gemini]
#
# Obtain keys at: https://aistudio.google.com/apikey
#
# Number of Gemini API keys configured.
# PoolGate loads keys sequentially from GEMINI_API_KEY_01 … GEMINI_API_KEY_N.
# Ensure TOTAL_GEMINI_KEYS matches the number of key entries below.

TOTAL_GEMINI_KEYS=3

GEMINI_API_KEY_01=
GEMINI_API_KEY_02=
GEMINI_API_KEY_03=

# ============================================================================
# GOOGLE GEMINI — Rate Limiting
# ============================================================================
# Free-tier limits for gemini-2.5-flash / gemini-3.5-flash:
#   RPM=5, TPM=250,000, RPD=20
# Adjust if you are on a paid plan.

# Max requests per minute per key.
# Built-in default when this variable is unset: 5
GEMINI_MAX_RPM=5

# Max concurrent in-flight requests per key.
# Built-in default when this variable is unset: 5
GEMINI_MAX_ACTIVE=5

# Seconds a key is held in cooldown after receiving a 429.
# Built-in default when this variable is unset: 60
GEMINI_COOLDOWN_SECS=60

# Consecutive non-rate-limit failures before a key is marked FAILED.
# Built-in default when this variable is unset: 3
GEMINI_FAILURE_THRESHOLD=3

# ============================================================================
# GOOGLE GEMINI — Throughput
# ============================================================================
# Maximum concurrent requests during async batch operations.
# Keep this low relative to RPM to avoid exhausting free-tier quota.
# Built-in default when this variable is unset: 10
GEMINI_BATCH_CONCURRENCY=10

# ============================================================================
# GOOGLE GEMINI — Retry Policy
# ============================================================================
# Built-in default when this variable is unset: 3
GEMINI_MAX_RETRIES=3

# Initial retry delay in seconds.
GEMINI_BASE_BACKOFF=1.0

# Maximum retry delay cap in seconds.
GEMINI_MAX_BACKOFF=30.0

# ============================================================================
# GOOGLE GEMINI — Session Management
# ============================================================================
GEMINI_SESSION_TTL_HOURS=24

# ============================================================================
# GOOGLE GEMINI — Logging
# ============================================================================
# Enable verbose debugging.
# Accepted: true | false | 1 | 0 | yes | no
GEMINI_DEBUG=false

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
GEMINI_LOG_LEVEL=INFO
