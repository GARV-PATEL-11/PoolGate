# ============================================================================
# PoolGate Configuration
# ============================================================================
# Copy this file to `.env` and update the values as needed.
#
#   cp .env.example .env
# ============================================================================

# ============================================================================
# Groq API Keys (Required)
# ============================================================================
# Total number of Groq API keys configured below.
#
# PoolGate will load keys from:
#   GROQ_API_KEY_01
#   GROQ_API_KEY_02
#   GROQ_API_KEY_03
#   ...
#
# At least one valid API key is required for PoolGate to start.
# Add or remove entries as needed and update TOTAL_GROQ_KEYS accordingly.
# ============================================================================

TOTAL_GROQ_KEYS=10

GROQ_API_KEY_01=
GROQ_API_KEY_02=
GROQ_API_KEY_03=
GROQ_API_KEY_04=
GROQ_API_KEY_05=
GROQ_API_KEY_06=
GROQ_API_KEY_07=
GROQ_API_KEY_08=
GROQ_API_KEY_09=
GROQ_API_KEY_10=

# ============================================================================
# Batch Processing
# ============================================================================
# Maximum number of requests processed concurrently during batch workloads.
#
# Higher values increase throughput but may trigger rate limits sooner,
# depending on the number of available keys and per-model limits.
# ============================================================================

GROQ_BATCH_CONCURRENCY=20

# ============================================================================
# Retry Configuration
# ============================================================================
# Maximum retry attempts for transient failures (network issues,
# service unavailability, rate limiting, etc.).
GROQ_MAX_RETRIES=3

# Initial delay (in seconds) before the first retry.
# Subsequent retries follow exponential backoff:
#   Example with GROQ_BASE_BACKOFF=1.0 → 1s → 2s → 4s → ...
GROQ_BASE_BACKOFF=1.0

# Maximum delay (in seconds) between retry attempts.
# Caps exponential backoff to prevent unbounded wait times.
GROQ_MAX_BACKOFF=30.0

# ============================================================================
# Session Management
# ============================================================================
# Session lifetime in hours.
# Sessions older than this value are eligible for automatic expiry and cleanup.
# ============================================================================

GROQ_SESSION_TTL_HOURS=24

# ============================================================================
# Logging & Diagnostics
# ============================================================================
# Enable verbose debug output.
#
# Accepted values: true | false | 1 | 0 | yes | no
# Recommended:     false (production) | true (development / troubleshooting)
GROQ_DEBUG=false

# Logging verbosity level.
#
# Supported values: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Recommended:      INFO (normal operation) | DEBUG (troubleshooting)
GROQ_LOG_LEVEL=INFO