# EditorConfig — https://editorconfig.org
# Ensures consistent formatting across editors and IDEs.

root = true


# ── All files ─────────────────────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
tab_width = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100


# ── Python ────────────────────────────────────────────────────────────────────
[*.{py,pyw}]
indent_style = tab
indent_size = 4
tab_width = 4
max_line_length = 120


# ── TOML ──────────────────────────────────────────────────────────────────────
[*.toml]
indent_style = space
indent_size = 4


# ── Lockfiles ─────────────────────────────────────────────────────────────────
# Generated files — only enforce a trailing newline.
[{Cargo.lock,Cargo.toml.orig,Gopkg.lock,Pipfile,pdm.lock,poetry.lock,uv.lock}]
insert_final_newline = true


# ── YAML ──────────────────────────────────────────────────────────────────────
[*.{yml,yaml}]
indent_style = space
indent_size = 2


# ── JSON / JSONC ──────────────────────────────────────────────────────────────
[*.{json,jsonc,har,jsb2,jsb3}]
indent_style = space
indent_size = 2


# ── JSONL ─────────────────────────────────────────────────────────────────────
[*.jsonl]
insert_final_newline = true


# ── Markdown ──────────────────────────────────────────────────────────────────
[*.{md,markdown}]
trim_trailing_whitespace = false
max_line_length = off


# ── Shell scripts ─────────────────────────────────────────────────────────────
[*.{sh,bash,zsh}]
indent_style = space
indent_size = 2


# ── Makefile (tabs are syntactically required) ────────────────────────────────
[Makefile]
indent_style = tab